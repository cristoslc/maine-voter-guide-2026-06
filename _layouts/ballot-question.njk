---
layout: base
templateEngineOverride: njk,md
---

{% set bqMatch = ballotQuestions | findBallotQuestion(page.fileSlug) %}
{% set bqJurisdiction = bqMatch.jurisdiction %}
{% set jurisdictionObj = jurisdictions | findById(bqJurisdiction) %}

<nav class="breadcrumb" aria-label="Breadcrumb">
  <a href="{{ '/' | url }}">Home</a> &rsaquo; <a href="/{{ bqJurisdiction }}/">{{ jurisdictionObj.name or bqJurisdiction }}</a> &rsaquo; {{ title }}
</nav>

<div class="race-header">
  <h1>{{ title }}</h1>
</div>

<div class="ballot-group">
  <div class="ballot-primary">
    {{ content | safe }}
  </div>

  {% if sidebar %}
  <aside class="ballot-secondary">
    {{ sidebar | safe }}
  </aside>
  {% endif %}
</div>
