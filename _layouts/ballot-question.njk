---
layout: base
templateEngineOverride: njk,md
---

<nav class="breadcrumb" aria-label="Breadcrumb">
  <a href="{{ '/' | url }}">Home</a> &rsaquo; <a href="/{{ (ballotQuestions | findBallotQuestion(page.fileSlug)).jurisdiction }}/">{{ (jurisdictions | find((ballotQuestions | findBallotQuestion(page.fileSlug)).jurisdiction)).name or (ballotQuestions | findBallotQuestion(page.fileSlug)).jurisdiction }}</a> &rsaquo; {{ title }}
</nav>

<div class="race-header">
  <h1>{{ title }}</h1>
</div>

<div class="ballot-group">
  <div class="ballot-primary">
    {{ content | safe }}
  </div>

  {% if sidebar %}
  <aside class="ballot-secondary">
    {{ sidebar | safe }}
  </aside>
  {% endif %}
</div>
