---
layout: base
eleventyComputed:
  title: "{{ race.title }}"
---
{#
  Trust boundary: data rendered via | safe (candidate.meta, pos.text,
  sec.text, race.context, posSource.url, compareTable values) comes from
  hand-curated data files committed to this repository. Only trusted
  editors with commit access can modify this content. A build-time lint
  (test/data-integrity.test.js → "no disallowed HTML tags") validates that
  data strings do not contain <script>, <iframe>, <object>, <embed>, or
  <form> tags. Do not use | safe on user-supplied runtime input.
#}

{% set raceOffice = race.office | officeSlugFromTitle | resolveOffice(offices) %}
{% set raceSources = race | collectSources(sources) %}
{% set crossPartyRace = race | findCrossPartyRace(races) %}
{% set partyBlock = race.party %}
{% set resolvedParty = partyBlock.party | resolveParty(parties) %}
{% set isContested = partyBlock.candidates and (partyBlock.candidates | length) > 1 %}

<nav class="breadcrumb" aria-label="Breadcrumb">
  <a href="{{ '/' | url }}">Home</a> &rsaquo; <a href="/{{ race.jurisdiction }}/">{{ (jurisdictions | find(race.jurisdiction)).name or race.jurisdiction }}</a> &rsaquo; {{ race.title }}
</nav>

<div class="race-header">
  <h1>{{ race.title }}</h1>
</div>

<p>{{ race.voting }}</p>
<p><span class="card-tag {% if isContested %}contested{% else %}uncontested{% endif %}">{% if isContested %}Contested{% else %}Uncontested{% endif %}</span></p>
{% if raceOffice %}<p><strong>What a {{ raceOffice.officerTitle }} does</strong>: {{ raceOffice.officeDesc | safe }}</p>{% elif race.officeDesc %}<p><strong>What a {{ race.office }} does</strong>: {{ race.officeDesc | safe }}</p>{% endif %}
{% if race.context %}<p><strong>Context</strong>: {{ race.context | safe }}</p>{% endif %}

{% for sec in partyBlock.raceWideSecondary %}
  <div class="race-wide-box">
    <h3>{{ sec.heading }}</h3>
    {% if sec.rows %}
      <table class="poll-mini">
        {% for row in sec.rows %}
          <tr><td>{{ row[0] }}</td><td>{{ row[1] | safe }}</td></tr>
        {% endfor %}
      </table>
    {% elif sec.text %}
      {{ sec.text | safe }}
    {% endif %}
    {% if sec.source %}
      <p class="source-ref">{{ sec.source | safe }}</p>
    {% endif %}
  </div>
{% endfor %}

{% for candidate in partyBlock.candidates %}
  {% set candidateEntry = candidate.name | resolveCandidate(candidates) %}
  <div class="candidate-group">
    <div class="candidate-primary">
      <div class="candidate-head">
        <h2>{{ candidate.name }}{% if candidateEntry and candidateEntry.incumbent %} <span class="incumbent-badge">(Incumbent)</span>{% endif %}</h2>
        <span class="party-tag {{ candidate.tag }}">
          {% if resolvedParty %}{{ resolvedParty.shortName }}{% elif candidate.tag == "d" %}Democratic{% elif candidate.tag == "r" %}Republican{% else %}{{ candidate.tag }}{% endif %}
        </span>
      </div>

      {% if candidate.meta %}<div class="candidate-meta">{{ candidate.meta | safe }}{% if candidateEntry and candidateEntry.campaignWebsite %} · <a href="{{ candidateEntry.campaignWebsite }}">Campaign website</a>{% endif %}{% if candidateEntry and candidateEntry.ballotpediaUrl %} · <a href="{{ candidateEntry.ballotpediaUrl }}">Ballotpedia</a>{% endif %}</div>{% elif candidateEntry and candidateEntry.campaignWebsite %}<div class="candidate-meta"><a href="{{ candidateEntry.campaignWebsite }}">Campaign website</a>{% if candidateEntry.ballotpediaUrl %} · <a href="{{ candidateEntry.ballotpediaUrl }}">Ballotpedia</a>{% endif %}</div>{% elif candidateEntry and candidateEntry.ballotpediaUrl %}<div class="candidate-meta"><a href="{{ candidateEntry.ballotpediaUrl }}">Ballotpedia</a></div>{% endif %}

      {% if candidate.primaryContent and candidate.primaryContent | length %}
        <h3>Platform</h3>
        {% for pos in candidate.primaryContent %}
          {% set resolvedIssue = pos.issue | resolveIssue(issues) %}
          <div class="position">
            {% if resolvedIssue %}<div class="issue-label">{{ resolvedIssue.label }}</div>{% elif pos.issue %}<div class="issue-label">{{ pos.issue }}</div>{% endif %}
            <div class="issue-text">{{ pos.text | safe }}</div>
          {% if pos.sourceId %}
            {% set posSource = pos.sourceId | resolveSource(sources) %}
            {% if posSource %}<div class="source-ref"><a href="{{ posSource.url }}">{{ posSource.label }}</a></div>{% endif %}
          {% endif %}
          </div>
        {% endfor %}
      {% endif %}
    </div>

    {% if candidate.secondaryContent and candidate.secondaryContent | length %}
      <aside class="candidate-secondary">
        {% for sec in candidate.secondaryContent %}
          <div class="context-section">
            <h4>{{ sec.heading }}</h4>
            {{ sec.text | safe }}
          </div>
        {% endfor %}
      </aside>
    {% endif %}
  </div>
{% endfor %}

{% if partyBlock.compareTable %}
  <hr>
  <h2>Comparison</h2>
  <table class="compare-table">
    <thead>
      <tr><th></th>
        {% for h in partyBlock.compareTable.headers %}
          <th>{{ h }}</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in partyBlock.compareTable.rows %}
        <tr>
          <td data-label="Issue"><strong>{{ row.issue }}</strong></td>
          {% for h in partyBlock.compareTable.headers %}
            <td data-label="{{ h }}">{{ row[h | lower] | safe }}</td>
          {% endfor %}
        </tr>
      {% endfor %}
    </tbody>
  </table>
{% endif %}

{% if crossPartyRace and crossPartyRace.party %}
  {% set cppParty = crossPartyRace.party %}
  <hr>
  <h2>Who You'd Face in November</h2>
  <div class="callout">
    <p><strong>Note:</strong> You vote in only one primary. The {% set oppParty = (crossPartyRace.party.party | resolveParty(parties)) %}{% if oppParty %}{{ oppParty.shortName }}{% else %}opposing{% endif %} field is shown below so you can evaluate how this primary's candidates match up in the general election.</p>
  </div>
  {% for opp in cppParty.candidates %}
    {% set oppEntry = opp.name | resolveCandidate(candidates) %}
    <div class="candidate-card">
      <div class="candidate-head">
        <h3>{{ opp.name }}{% if oppEntry and oppEntry.incumbent %} <span class="incumbent-badge">(Incumbent)</span>{% endif %}</h3>
        {% set oppPartyObj = crossPartyRace.party.party | resolveParty(parties) %}
        <span class="party-tag {{ opp.tag }}">{% if oppPartyObj %}{{ oppPartyObj.shortName }}{% else %}{{ crossPartyRace.party.party }}{% endif %}</span>
      </div>
      {% if opp.meta %}<div class="candidate-meta">{{ opp.meta | safe }}{% if oppEntry and oppEntry.campaignWebsite %} · <a href="{{ oppEntry.campaignWebsite }}">Campaign website</a>{% endif %}{% if oppEntry and oppEntry.ballotpediaUrl %} · <a href="{{ oppEntry.ballotpediaUrl }}">Ballotpedia</a>{% endif %}</div>{% elif oppEntry and oppEntry.campaignWebsite %}<div class="candidate-meta"><a href="{{ oppEntry.campaignWebsite }}">Campaign website</a>{% if oppEntry.ballotpediaUrl %} · <a href="{{ oppEntry.ballotpediaUrl }}">Ballotpedia</a>{% endif %}</div>{% elif oppEntry and oppEntry.ballotpediaUrl %}<div class="candidate-meta"><a href="{{ oppEntry.ballotpediaUrl }}">Ballotpedia</a></div>{% endif %}
      {% for pos in opp.primaryContent %}
        {% set resolvedIssue = pos.issue | resolveIssue(issues) %}
        <div class="position">
          {% if resolvedIssue %}<div class="issue-label">{{ resolvedIssue.label }}</div>{% elif pos.issue %}<div class="issue-label">{{ pos.issue }}</div>{% endif %}
          <div class="issue-text">{{ pos.text | safe }}</div>
          {% if pos.sourceId %}
            {% set posSource = pos.sourceId | resolveSource(sources) %}
            <div class="source-ref"><a href="{{ posSource.url }}">{{ posSource.label }}</a></div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endfor %}
{# crossPartyPreview: inline opponent data embedded directly in the race object, used when no opposing-party race exists in the same jurisdiction #}
{% elif partyBlock.crossPartyPreview and partyBlock.crossPartyPreview | length %}
  <hr>
  <h2>Who You'd Face in November</h2>
  <div class="callout">
    <p><strong>Note:</strong> You vote in only one primary. The {{ partyBlock.crossPartyPreview[0].party }} field is shown below so you can evaluate how this primary's candidates match up in the general election.</p>
  </div>
  {% for opp in partyBlock.crossPartyPreview %}
    <div class="candidate-card">
      <div class="candidate-head">
        <h3>{{ opp.name }}</h3>
        <span class="party-tag {{ opp.tag }}">{{ opp.party }}</span>
      </div>
      {% if opp.meta %}<div class="candidate-meta">{{ opp.meta | safe }}</div>{% endif %}
      {% for pos in opp.primaryContent %}
        {% set resolvedIssue = pos.issue | resolveIssue(issues) %}
        <div class="position">
          {% if resolvedIssue %}<div class="issue-label">{{ resolvedIssue.label }}</div>{% elif pos.issue %}<div class="issue-label">{{ pos.issue }}</div>{% endif %}
          <div class="issue-text">{{ pos.text | safe }}</div>
          {% if pos.sourceId %}
            {% set posSource = pos.sourceId | resolveSource(sources) %}
            <div class="source-ref"><a href="{{ posSource.url }}">{{ posSource.label }}</a></div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endfor %}
{% endif %}

{# Dual source paths: raceSources (computed via collectSources filter) is preferred;
   sourcesMain/sourcesSidebar is the inline fallback for races without computed sources. #}
{% if raceSources | length %}
  <hr>
  <h3>Sources</h3>
  <p>
    {% for s in raceSources %}
      <a href="{{ s.url }}">{{ s.label }}</a>{% if not loop.last %} · {% endif %}
    {% endfor %}
  </p>
{% elif race.sourcesMain and race.sourcesMain | length %}
  <hr>
  <h3>Sources</h3>
  <p>
    {% for sid in race.sourcesMain %}
      {% set s = sid | resolveSource(sources) %}
      {% if s %}<a href="{{ s.url }}">{{ s.label }}</a>{% if not loop.last %} · {% endif %}{% endif %}
    {% endfor %}
  </p>
{% endif %}

{% if race.sourcesSidebar and race.sourcesSidebar | length %}
  <p>
    {% for sid in race.sourcesSidebar %}
      {% set s = sid | resolveSource(sources) %}
      {% if s %}<a href="{{ s.url }}">{{ s.label }}</a>{% if not loop.last %} · {% endif %}{% endif %}
    {% endfor %}
  </p>
{% endif %}

<p><em>Last updated: May 31, 2026.</em></p>
